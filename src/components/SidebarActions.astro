---
import type { Props } from '@astrojs/starlight/props';

const props = Astro.props as unknown as Props;
const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();
const encodedUrl = encodeURIComponent(currentUrl);
const title = props.entry?.data?.title || '';
const encodedTitle = encodeURIComponent(title);

const isDocPage = Astro.url.pathname !== '/' && !Astro.url.pathname.startsWith('/404')
  && !Astro.url.pathname.startsWith('/legal');

// Agent action URLs
const chatGptUrl = `https://chatgpt.com/?q=${encodeURIComponent(`Summarize and explain this page: ${currentUrl}`)}`;
const claudeUrl = `https://claude.ai/new?q=${encodeURIComponent(`Read and discuss this page: ${currentUrl}`)}`;
const perplexityUrl = `https://www.perplexity.ai/search?q=${encodedUrl}`;
---

{isDocPage && (
  <div class="sidebar-actions">
    <div class="sidebar-actions-section">
      <span class="sidebar-actions-label">Share</span>
      <div class="sidebar-actions-buttons">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-action-btn"
          aria-label="Share on X (Twitter)"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-action-btn"
          aria-label="Share on LinkedIn"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a
          href={`https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-action-btn"
          aria-label="Share on Reddit"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.996.913.513 0 2.155-.071 2.997-.913a.326.326 0 0 0-.013-.463.33.33 0 0 0-.464.013c-.548.533-1.684.73-2.512.73-.828 0-1.974-.196-2.522-.73a.326.326 0 0 0-.251-.107z"/></svg>
        </a>
      </div>
    </div>

    <div class="sidebar-actions-section">
      <span class="sidebar-actions-label">Agent Actions</span>
      <div class="sidebar-actions-buttons">
        <button
          class="sidebar-action-btn"
          aria-label="Copy URL for AI"
          onclick="navigator.clipboard.writeText(window.location.href).then(() => { this.innerHTML = '<svg viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'2\'><path d=\'M20 6L9 17l-5-5\'></path></svg>'; setTimeout(() => location.reload(), 1500); })"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
        <a
          href={chatGptUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-action-btn"
          aria-label="Discuss with ChatGPT"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.787A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
        </a>
        <a
          href={claudeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-action-btn"
          aria-label="Discuss with Claude"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.864 3.722a.862.862 0 0 0-1.381-.645l-4.246 3.39a.587.587 0 0 0-.214.457v.066a.587.587 0 0 0 .214.457l4.246 3.39a.862.862 0 0 0 1.381-.645V3.722Zm3.738 8.672a.862.862 0 0 0-.645-1.381h-.066a.862.862 0 0 0-.645.214l-3.39 4.246a.587.587 0 0 0-.13.371v.066c0 .133.044.262.13.371l3.39 4.246a.862.862 0 0 0 1.381-.645V12.394h-.025Zm-8.672 3.738a.862.862 0 0 0 1.381.645l4.246-3.39a.587.587 0 0 0 .214-.457v-.066a.587.587 0 0 0-.214-.457l-4.246-3.39a.862.862 0 0 0-1.381.645v6.47ZM5.394 12.394a.862.862 0 0 0 .645 1.381h.066a.862.862 0 0 0 .645-.214l3.39-4.246a.587.587 0 0 0 .13-.371v-.066a.587.587 0 0 0-.13-.371L6.75 4.261a.862.862 0 0 0-1.381.645v7.488h.025ZM12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0Z"/></svg>
        </a>
        <a
          href={perplexityUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-action-btn"
          aria-label="Research with Perplexity"
        >
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm0 1.5a10.5 10.5 0 1 1 0 21 10.5 10.5 0 0 1 0-21zm4.37 5.39l-1.06 1.06a4.5 4.5 0 0 0-6.62 0l-1.06-1.06a6 6 0 0 1 8.74 0zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>
        </a>
      </div>
    </div>
  </div>
)}

<style>
  .sidebar-actions {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-actions-section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .sidebar-actions-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
  }

  .sidebar-actions-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .sidebar-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    border: 1px solid var(--sl-color-gray-5);
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    text-decoration: none;
    transition: color 150ms ease, border-color 150ms ease, background-color 150ms ease;
  }

  .sidebar-action-btn:hover {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }

  .sidebar-action-btn:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .sidebar-action-btn svg {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }
</style>
