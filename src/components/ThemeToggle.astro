---
// One-click theme toggle: switches between dark and light.
// Starlight renders the ThemeSelect override in both the desktop header
// and the mobile menu, so this component is mounted multiple times.
// Avoid a hardcoded id (would collide) and bind to every instance.
---

<button
  class="theme-toggle-btn"
  aria-label="Toggle theme"
  title="Toggle dark/light theme"
>
  <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script is:inline>
  (function() {
    function toggle() {
      var current = document.documentElement.dataset.theme;
      var next = current === 'light' ? 'dark' : 'light';
      if (window.StarlightThemeProvider) {
        window.StarlightThemeProvider.updatePickers(next);
      }
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('starlight-theme', next); } catch(e) {}
    }

    function bind(btn) {
      if (btn.__themeToggleBound) return;
      btn.__themeToggleBound = true;
      btn.addEventListener('click', toggle);
    }

    // Bind to every instance (desktop header + mobile menu).
    var btns = document.querySelectorAll('.theme-toggle-btn');
    btns.forEach(bind);

    // Late-safety: if a button mounts after this script runs (it shouldn't,
    // since is:inline scripts execute in order), catch it via the DOM.
    new MutationObserver(function(muts) {
      for (var i = 0; i < muts.length; i++) {
        muts[i].addedNodes.forEach(function(node) {
          if (node.nodeType !== 1) return;
          if (node.classList && node.classList.contains('theme-toggle-btn')) bind(node);
          node.querySelectorAll && node.querySelectorAll('.theme-toggle-btn').forEach(bind);
        });
      }
    }).observe(document.body, { childList: true, subtree: true });
  })();
</script>
