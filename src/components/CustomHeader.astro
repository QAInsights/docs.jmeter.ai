---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import SocialIcons from 'lucode-starlight/components/overrides/SocialIcons.astro';
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import ThemeSelect from 'lucode-starlight/components/overrides/ThemeSelect.astro';
import SiteTitle from 'lucode-starlight/components/overrides/SiteTitle.astro';

import NavBar from '../../node_modules/lucode-starlight/components/overrides/parts/NavBar.astro';
import MobileMenuToggle from '../../node_modules/lucode-starlight/components/overrides/parts/MobileMenuToggle.astro';

/** render the `Search` component if Pagefind is enabled or the default search component has been overridden. */
const shouldRenderSearch =
    config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<MobileMenuToggle />

<div class="header-grid">
    <div class="header-left">
        <div class="site-title-wrapper">
            <SiteTitle />
            <NavBar />
        </div>
    </div>

    <div class="search-container-center">
        {shouldRenderSearch && <Search />}
    </div>

    <div class="header-right">
        <nav class="header-nav">
            <div>
                <SocialIcons />
            </div>
            <div>
                <ThemeSelect />
            </div>
            <div>
                <LanguageSelect />
            </div>
            <div class="mobile-search-wrapper">
                <button class="mobile-search-btn" aria-label="Search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.3-4.3" />
                    </svg>
                </button>
            </div>
        </nav>
    </div>
</div>

<style>
    .header-grid {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        height: 100%;
        gap: 1rem;
    }

    .header-left {
        justify-self: start;
        display: flex;
        align-items: center;
    }

    .site-title-wrapper {
        display: none;
    }

    @media (min-width: 768px) {
        .site-title-wrapper {
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
    }

    .search-container-center {
        display: none;
        justify-content: center;
        align-items: center;
    }

    @media (min-width: 1024px) {
        .search-container-center {
            display: flex;
        }
    }

    .header-right {
        justify-self: end;
        gap: 0.5rem;
        align-items: center;
        display: flex;
        flex-shrink: 0;
    }

    .header-nav {
        gap: 0.125rem;
        align-items: center;
        display: flex;
    }

    .header-nav > div:has(> :not(script)) {
        display: flex;
        align-items: center;
    }

    .header-nav > div:has(> :not(script)) + div:has(> :not(script)) {
        position: relative;
        margin-left: calc(var(--spacing) * 1);
        padding-left: calc(var(--spacing) * 3);
    }

    .header-nav > div:has(> :not(script)) + div:has(> :not(script))::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        width: 1px;
        height: 1rem;
        background-color: color-mix(in oklab, var(--border) 85%, transparent);
        transform: translateY(-50%);
    }

    .mobile-search-wrapper {
        display: flex;
        align-items: center;
    }

    @media (min-width: 1024px) {
        .mobile-search-wrapper {
            display: none;
        }
    }

    .mobile-search-btn {
        all: unset;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: calc(var(--radius) - 2px);
        cursor: pointer;
        color: color-mix(in oklab, var(--foreground) 76%, var(--muted-foreground));
        background-color: transparent;
        transition: color 0.15s, background-color 0.15s;
    }

    .mobile-search-btn:hover {
        color: var(--accent-foreground);
        background-color: color-mix(in oklab, var(--accent) 80%, transparent);
    }

</style>

<style is:global>
    /* Hide the centered search bar on mobile — compact icon is used instead */
    .search-container-center {
        display: none !important;
    }

    /* Hide DocSearch/Pagefind button on mobile */
    .DocSearch-Button,
    site-search button[data-open-modal] {
        display: none !important;
    }

    @media (min-width: 1024px) {
        .search-container-center {
            display: flex !important;
        }

        /* Google-style Animated Gradient Border on the Search Button */
        .DocSearch-Button,
        site-search button[data-open-modal] {
            display: flex !important;
            position: relative !important;
            z-index: 1 !important;
            border: none !important;
            background: transparent !important;
            overflow: visible !important;
            min-width: 320px !important;
        }

        .DocSearch-Button:hover {
            background: transparent !important;
        }

        /* Animated gradient background */
        .DocSearch-Button::before {
            content: '' !important;
            position: absolute !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            bottom: 0 !important;
            z-index: -2 !important;
            border-radius: 0.5rem !important;
            background: linear-gradient(90deg, #4285F4, #EA4335, #FBBC05, #34A564, #4285F4) !important;
            background-size: 400% 100% !important;
            animation: google-gradient 4s linear infinite !important;
        }

        /* Solid inner mask background */
        .DocSearch-Button::after {
            content: '' !important;
            position: absolute !important;
            top: 1px !important;
            left: 1px !important;
            right: 1px !important;
            bottom: 1px !important;
            z-index: -1 !important;
            border-radius: calc(0.5rem - 1px) !important;
            background: var(--sl-color-black) !important;
            transition: all 0.2s ease !important;
        }

        .DocSearch-Button:hover::after {
            top: 2px !important;
            left: 2px !important;
            right: 2px !important;
            bottom: 2px !important;
            border-radius: calc(0.5rem - 2px) !important;
        }
    }

    @keyframes google-gradient {
        0% {
            background-position: 0% 50%;
        }
        100% {
            background-position: 400% 50%;
        }
    }
</style>

<script>
    document.querySelector('.mobile-search-btn')?.addEventListener('click', () => {
        const docSearchBtn = document.querySelector<HTMLElement>('.DocSearch-Button');
        if (docSearchBtn) {
            docSearchBtn.click();
            return;
        }
        const pagefindBtn = document.querySelector<HTMLElement>('site-search button[data-open-modal]');
        pagefindBtn?.click();
    });
</script>
