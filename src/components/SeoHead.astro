---
import StarlightHead from '@astrojs/starlight/components/Head.astro';
import type { Props } from '@astrojs/starlight/props';
import { buildFaqJsonLd } from '../faq-schema.mjs';
import { buildHowToJsonLd } from '../howto-schema.mjs';

const route = Astro.locals.starlightRoute;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const entryData = route?.entry?.data;
const rawTitle = entryData?.title?.trim();
const isHome = Astro.url.pathname === '/' || !rawTitle;

// SEO frontmatter overrides
const seoTitleRaw = entryData?.seoTitle;
const displayTitle = seoTitleRaw || rawTitle;
const seoTitle = isHome ? 'docs.jmeter.ai - Apache JMeter Community Documentation' : `${displayTitle} | docs.jmeter.ai`;
const seoDescription = entryData?.description || 'Community-maintained documentation for Apache JMeter with improved navigation, search, and reading experience.';
const seoKeywords = entryData?.keywords;
const seoDifficulty = entryData?.difficulty;
const seoCanonicalTopic = entryData?.canonicalTopic;

// Resolve date for structured data (Starlight provides lastUpdated from git
// as a top-level Date on the route object, not on entry.data)
const resolvedDate = route?.lastUpdated instanceof Date
  ? route.lastUpdated.toISOString()
  : null;

// Difficulty → schema.org proficiencyLevel mapping
const proficiencyMap: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// TechArticle JSON-LD for doc pages
const isDocPage = Astro.url.pathname !== '/' && !Astro.url.pathname.startsWith('/404');
const jsonLd = isDocPage ? {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: displayTitle || 'docs.jmeter.ai',
  description: seoDescription,
  url: canonicalUrl,
  ...(resolvedDate ? { dateModified: resolvedDate, datePublished: resolvedDate } : {}),
  publisher: {
    '@type': 'Organization',
    name: 'docs.jmeter.ai',
    url: 'https://docs.jmeter.ai',
  },
  author: {
    '@type': 'Organization',
    name: 'Apache JMeter Community',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  ...(seoDifficulty && proficiencyMap[seoDifficulty] ? { proficiencyLevel: proficiencyMap[seoDifficulty] } : {}),
  about: {
    '@type': 'SoftwareApplication',
    name: 'Apache JMeter',
    applicationCategory: 'DeveloperApplication',
  },
} : null;

// BreadcrumbList JSON-LD
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: 'https://docs.jmeter.ai/' },
];
let currentPath = '';
for (const segment of pathSegments) {
  currentPath += `/${segment}`;
  const name = segment.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  breadcrumbItems.push({ name, url: `https://docs.jmeter.ai${currentPath}` });
}

const breadcrumbJsonLd = breadcrumbItems.length > 1 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
} : null;

// Modify the Starlight route head array dynamically to replace auto-generated title/description tags
if (route && route.head) {
  route.head = route.head.map((tag) => {
    // 1. Update Title tag
    if (tag.tag === 'title') {
      return { ...tag, content: seoTitle };
    }
    
    // 2. Update Description tag
    if (tag.tag === 'meta' && tag.attrs?.name === 'description') {
      return { ...tag, attrs: { ...tag.attrs, content: seoDescription } };
    }

    // 3. Update OG Title
    if (tag.tag === 'meta' && tag.attrs?.property === 'og:title') {
      return { ...tag, attrs: { ...tag.attrs, content: seoTitle } };
    }

    // 4. Update OG Description
    if (tag.tag === 'meta' && tag.attrs?.property === 'og:description') {
      return { ...tag, attrs: { ...tag.attrs, content: seoDescription } };
    }

    // 5. Update Twitter Title
    if (tag.tag === 'meta' && tag.attrs?.name === 'twitter:title') {
      return { ...tag, attrs: { ...tag.attrs, content: seoTitle } };
    }

    // 6. Update Twitter Description
    if (tag.tag === 'meta' && tag.attrs?.name === 'twitter:description') {
      return { ...tag, attrs: { ...tag.attrs, content: seoDescription } };
    }

    // 7. Make sure twitter:card is summary_large_image
    if (tag.tag === 'meta' && tag.attrs?.name === 'twitter:card') {
      return { ...tag, attrs: { ...tag.attrs, content: 'summary_large_image' } };
    }

    return tag;
  });

  // Helper to check if a tag already exists
  const hasTag = (tagType: string, attrKey: string, attrVal: string) =>
    route.head.some(t => t.tag === tagType && t.attrs?.[attrKey] === attrVal);

  // Google Analytics (gtag.js)  -  injected at the front of <head> so it loads
  // immediately. Gated to production so dev/preview visits aren't tracked.
  if (import.meta.env.PROD && !hasTag('script', 'src', 'https://www.googletagmanager.com/gtag/js?id=G-MVZN6CMXYQ')) {
    route.head.unshift(
      {
        tag: 'script',
        attrs: { async: true, src: 'https://www.googletagmanager.com/gtag/js?id=G-MVZN6CMXYQ' },
      },
      {
        tag: 'script',
        content: `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-MVZN6CMXYQ');`,
      }
    );
  }

  // Inject robots meta tag
  if (!hasTag('meta', 'name', 'robots')) {
    route.head.push({ tag: 'meta', attrs: { name: 'robots', content: 'index, follow' } });
  }

  // Inject keywords meta tag from frontmatter
  if (seoKeywords && seoKeywords.length > 0 && !hasTag('meta', 'name', 'keywords')) {
    route.head.push({ tag: 'meta', attrs: { name: 'keywords', content: seoKeywords.join(', ') } });
  }

  // Inject canonical-topic link for topic-cluster signals
  if (seoCanonicalTopic && !hasTag('link', 'rel', 'canonical-topic')) {
    route.head.push({
      tag: 'link',
      attrs: { rel: 'canonical-topic', href: `/topics/${seoCanonicalTopic}/` },
    });
  }

  // Satoshi typeface from Fontshare (variable weight)
  if (!hasTag('link', 'data-font', 'satoshi')) {
    route.head.unshift({
      tag: 'link',
      attrs: {
        rel: 'stylesheet',
        href: 'https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700,900&display=swap',
        'data-font': 'satoshi',
      },
    });
  }

  // Inject manifest link
  if (!hasTag('link', 'rel', 'manifest')) {
    route.head.push({ tag: 'link', attrs: { rel: 'manifest', href: '/manifest.json' } });
  }

  // Inject Open Graph Image tags
  if (!hasTag('meta', 'property', 'og:image')) {
    route.head.push({ tag: 'meta', attrs: { property: 'og:image', content: 'https://docs.jmeter.ai/images/og_preview.png' } });
    route.head.push({ tag: 'meta', attrs: { property: 'og:image:width', content: '1200' } });
    route.head.push({ tag: 'meta', attrs: { property: 'og:image:height', content: '628' } });
    route.head.push({ tag: 'meta', attrs: { property: 'og:image:type', content: 'image/png' } });
    route.head.push({ tag: 'meta', attrs: { property: 'og:image:alt', content: seoTitle } });
  }

  // Inject Twitter Image tags
  if (!hasTag('meta', 'name', 'twitter:image')) {
    route.head.push({ tag: 'meta', attrs: { name: 'twitter:image', content: 'https://docs.jmeter.ai/images/og_preview.png' } });
    route.head.push({ tag: 'meta', attrs: { name: 'twitter:image:alt', content: seoTitle } });
  }

  // Inject JSON-LD scripts
  if (jsonLd && !hasTag('script', 'data-schema', 'tech-article')) {
    route.head.push({
      tag: 'script',
      attrs: { type: 'application/ld+json', 'data-schema': 'tech-article' },
      content: JSON.stringify(jsonLd)
    });
  }
  if (breadcrumbJsonLd && !hasTag('script', 'data-schema', 'breadcrumb')) {
    route.head.push({
      tag: 'script',
      attrs: { type: 'application/ld+json', 'data-schema': 'breadcrumb' },
      content: JSON.stringify(breadcrumbJsonLd)
    });
  }

  // FAQPage JSON-LD for pages with curated Q&A content (Glossary, Hints &
  // Tips, Best Practices). Triggers expandable rich results in search
  // engines that support it.
  const faqJsonLd = buildFaqJsonLd(Astro.url.pathname, canonicalUrl);
  if (faqJsonLd && !hasTag('script', 'data-schema', 'faq-page')) {
    route.head.push({
      tag: 'script',
      attrs: { type: 'application/ld+json', 'data-schema': 'faq-page' },
      content: JSON.stringify(faqJsonLd)
    });
  }

  // HowTo JSON-LD for step-by-step tutorial pages (building test plans,
  // remote testing, building JMeter, creating templates). Triggers
  // step-by-step rich result cards in Google search.
  const howToJsonLd = buildHowToJsonLd(Astro.url.pathname, canonicalUrl);
  if (howToJsonLd && !hasTag('script', 'data-schema', 'how-to')) {
    route.head.push({
      tag: 'script',
      attrs: { type: 'application/ld+json', 'data-schema': 'how-to' },
      content: JSON.stringify(howToJsonLd)
    });
  }
}
---

<StarlightHead {...Astro.props} />
