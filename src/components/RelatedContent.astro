---
const nextStep = await Astro.slots.render('next-step');
const related = await Astro.slots.render('related');
const mistakes = await Astro.slots.render('mistakes');
const troubleshooting = await Astro.slots.render('troubleshooting');

const sections = [
  { title: 'Next Practical Step', icon: '→', slot: nextStep },
  { title: 'Related Reference', icon: '📖', slot: related },
  { title: 'Common Mistakes', icon: '⚠', slot: mistakes },
  { title: 'Troubleshooting', icon: '🔧', slot: troubleshooting },
].filter((s) => s.slot && String(s.slot).trim());

const colCount = Math.min(4, Math.max(1, sections.length));
---

{sections.length > 0 && (
  <div class="related-content" data-related-count={sections.length}>
    <h2 class="related-content-heading">Continue Learning</h2>
    <div
      class="related-content-grid"
      style={`--related-cols: ${colCount}`}
    >
      {sections.map((section) => (
        <article
          class={`related-card related-card--${section.title.toLowerCase().replace(/\s+/g, '-')}`}
        >
          <header class="related-card-header">
            <span class="related-card-icon" aria-hidden="true">{section.icon}</span>
            <h3 class="related-card-title">{section.title}</h3>
          </header>
          <div class="related-card-body" set:html={section.slot} />
        </article>
      ))}
    </div>
  </div>
)}
