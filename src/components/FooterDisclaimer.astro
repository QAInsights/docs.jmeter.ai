---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import GoToTop from './GoToTop.astro';
import PageActions from './PageActions.astro';
import ImageLightbox from './ImageLightbox.astro';

const isLandingPage = Astro.url.pathname === '/';
---

<div class="doc-footer-wrapper">
  <PageActions />
  <footer class="sl-flex doc-footer">
    <div class="meta sl-flex">
      <EditLink />
      <LastUpdated />
    </div>
    {!isLandingPage && <Pagination />}
  </footer>
  <footer class="site-footer">
    <div class="site-footer-top">
      <span>
        Created by <a href="https://qainsights.com" target="_blank" rel="noopener noreferrer">NaveenKumar Namachivayam</a>
      </span>
      <span class="footer-divider">&middot;</span>
      <span>
        Content synced from <a href="https://github.com/apache/jmeter" target="_blank" rel="noopener noreferrer">apache/jmeter</a> under Apache License 2.0
      </span>
    </div>
    <div class="site-footer-links">
      <a href="/legal/disclaimer">Disclaimer</a>
      <span class="footer-divider">&middot;</span>
      <a href="/legal/notice">NOTICE</a>
      <span class="footer-divider">&middot;</span>
      <a href="https://jmeter.apache.org" target="_blank" rel="noopener noreferrer">Official JMeter Site</a>
    </div>
    <p class="site-footer-trademark">
      Apache, Apache JMeter, JMeter, and the Apache JMeter logo are trademarks of the
      Apache Software Foundation. This site is an independent community resource and is
      not affiliated with, endorsed by, or sponsored by the Apache Software Foundation.
    </p>
  </footer>
  <GoToTop />
  <ImageLightbox />
</div>

<style>
  @layer starlight.core {
    .doc-footer-wrapper {
      margin-top: 2rem;
    }
    .doc-footer {
      flex-direction: column;
      gap: 1.5rem;
    }
    .doc-footer .meta {
      gap: 0.75rem 3rem;
      justify-content: space-between;
      flex-wrap: wrap;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }
  }
</style>
