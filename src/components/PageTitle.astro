---
const {
    entry: { data },
    pagination: { prev, next },
} = Astro.locals.starlightRoute;

const { title, description } = data;
const wordsPerMinute = 220;
const contentBody = typeof Astro.locals.starlightRoute?.entry?.body === 'string'
    ? Astro.locals.starlightRoute.entry.body
    : '';
const computedReadTime = contentBody
    ? `${Math.max(1, Math.ceil(contentBody.trim().split(/\s+/).filter(Boolean).length / wordsPerMinute))} min read`
    : undefined;
const guideMeta = [
    data.difficulty && { label: data.difficulty, title: 'Difficulty' },
    data.guideType && { label: data.guideType, title: 'Guide type' },
    (data.estimatedReadTime || computedReadTime) && { label: data.estimatedReadTime || computedReadTime, title: 'Estimated read time' },
    data.lastVerified && { label: `Verified ${data.lastVerified}`, title: 'Last verified version' },
].filter(Boolean);

// Suppress prev/next arrow buttons on the home (splash) page, where the
// title is intentionally blank and the landing layout has its own CTAs.
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHomePage = pathname === '/';

const leftArrow = 'M15 18l-6-6 6-6';
const rightArrow = 'M9 18l6-6-6-6';
---

<div data-slot="doc-title">
    <div data-slot="doc-title-header">
        <h1 id="_top">{title}</h1>

        <div data-slot="doc-title-actions">
            {
                !isHomePage && prev && (
                    <a class="link-button secondary icon-md" data-size="icon-md" href={prev.href} rel="prev" aria-label="Previous page">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={leftArrow} /></svg>
                    </a>
                )
            }

            {
                !isHomePage && next && (
                    <a class="link-button secondary icon-md" data-size="icon-md" href={next.href} rel="next" aria-label="Next page">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={rightArrow} /></svg>
                    </a>
                )
            }
        </div>
    </div>

    {
        description &&
        description.trim().toLowerCase() !== title.trim().toLowerCase() && (
            <p slot="doc-title-description">{description}</p>
        )
    }

    {
        !isHomePage && guideMeta.length > 0 && (
            <dl class="guide-meta" aria-label="Guide metadata">
                {guideMeta.map((item) => (
                    <div class="guide-meta-chip" title={item.title}>
                        <dt>{item.title}</dt>
                        <dd>{item.label}</dd>
                    </div>
                ))}
            </dl>
        )
    }
</div>

<style>
    div[data-slot='doc-title'] {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);
    }

    [data-slot='doc-title-header'] {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: calc(var(--spacing) * 2);

        @media (min-width: 640px) {
            align-items: start;
        }

        h1 {
            letter-spacing: var(--tracking-tight);
            font-weight: 600;
            font-size: 1.875rem;
            line-height: 2.25rem;
            scroll-margin: 5rem;
            margin: 0;
            color: var(--foreground);
        }

        [data-slot='doc-title-actions'] {
            display: flex;
            align-items: center;
            gap: calc(var(--spacing) * 2);
        }
    }

    [slot='doc-title-description'] {
        margin: 0;
        color: var(--muted-foreground);
        font-size: 1rem;
        line-height: 1.75rem;
        text-wrap: balance;

        @media (min-width: 640px) {
            max-width: 80%;
        }
    }

    .guide-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin: 0.35rem 0 0;
    }

    .guide-meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 9999px;
        background: var(--sl-color-gray-6);
        color: var(--sl-color-gray-2);
        font-size: 0.75rem;
        font-weight: 650;
        line-height: 1;
        padding: 0.35rem 0.6rem;
        text-transform: capitalize;
    }

    .guide-meta-chip dt {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .guide-meta-chip dd {
        margin: 0;
    }

    /* LinkButton  -  inlined from lucode-starlight (not exported as a public import). */
    .link-button {
        transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 0.15s;
        color: var(--primary-foreground);
        white-space: nowrap;
        gap: 0.5rem;
        justify-content: center;
        align-items: center;
        display: inline-flex;
        text-decoration: inherit;
        border: none;
        height: var(--button-height, calc(var(--spacing) * 8));
        width: var(--button-width, auto);
        font-weight: var(--button-font-weight, 500);
        font-size: var(--button-font-size, 0.875rem);
        line-height: var(--button-line-height, 1rem);
        padding-left: var(--button-padding-l, var(--button-padding-x, calc(var(--spacing) * 2.5)));
        padding-right: var(--button-padding-r, var(--button-padding-x, calc(var(--spacing) * 2.5)));
        border-radius: var(--button-radius, 9999px);

        &[data-size='icon-md'] {
            --button-height: calc(var(--spacing) * 7);
            --button-width: calc(var(--spacing) * 7);
            --button-padding-x: 0;
            --button-font-size: 0;
            --button-radius: calc(var(--radius) - 2px);
        }

        svg {
            flex-shrink: 0;
            pointer-events: none;
        }
    }

    .link-button.secondary {
        background-color: var(--secondary);
        color: var(--secondary-foreground);
    }

    .link-button.secondary:hover {
        background-color: color-mix(in oklab, var(--secondary) 80%, transparent);
    }
</style>
