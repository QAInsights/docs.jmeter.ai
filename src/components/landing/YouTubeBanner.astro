---
const PLAYLIST_URL = 'https://www.youtube.com/@QAInsights/playlists';
---

<a
  class="yt-banner"
  href={PLAYLIST_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Watch JMeter video tutorials on the QAInsights YouTube playlists"
>
  <div class="yt-banner-bg" aria-hidden="true">
    <span class="yt-orb yt-orb-a"></span>
    <span class="yt-orb yt-orb-b"></span>
    <span class="yt-orb yt-orb-c"></span>
  </div>

  <div class="yt-banner-visual" aria-hidden="true">
    <div class="yt-scene">
      <span class="yt-page yt-page-1"></span>
      <span class="yt-page yt-page-2"></span>
      <span class="yt-page yt-page-3"></span>
      <span class="yt-path">
        <span class="yt-node yt-node-1"></span>
        <span class="yt-node yt-node-2"></span>
        <span class="yt-node yt-node-3"></span>
      </span>
      <span class="yt-play-ring"></span>
      <span class="yt-play">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/>
        </svg>
      </span>
    </div>
  </div>

  <div class="yt-banner-copy">
    <span class="yt-banner-eyebrow">
      <svg class="yt-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8z"/>
        <path fill="var(--sl-color-gray-6)" d="M9.75 15.02l6.27-3.02-6.27-3.02v6.04z"/>
      </svg>
      Video learning
    </span>
    <h3 class="yt-banner-title">Learn JMeter with <span class="yt-accent">QAInsights</span></h3>
    <p class="yt-banner-desc">
      Curated YouTube playlists walk through recording, test plans, distributed runs, and analysis. Watch alongside the docs.
    </p>
    <span class="yt-banner-cta">
      Browse playlists
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M7 17L17 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M9 7h8v8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>