# Copy this file to `.env` (or set these in your Vercel project settings).
#
# Google Gemini API key — used by the /api/chat serverless function
# (Vercel AI SDK + @ai-sdk/google). The Vercel AI SDK itself is free and
# open-source; this key authenticates with Google's Gemini API, which has
# a free tier (15 RPM / 1,500 requests/day on gemini-2.5-flash).
#
# Get a key from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Cloudflare Turnstile — bot protection for the Ask AI chatbot.
# Prevents curl/automated abuse by verifying requests come from a real browser.
# Free, invisible to users (no puzzles). In dev, leave blank to skip validation.
#
# Create a widget at: https://dash.cloudflare.com/?to=/:account/turnstile
# Use "Managed" widget mode for invisible verification.
PUBLIC_TURNSTILE_SITEKEY=           # client-side sitekey (safe to expose)
TURNSTILE_SECRET_KEY=               # server-side secret key (never expose)
# Note: PUBLIC_TURNSTILE_SITE_KEY (with underscore) is also accepted as a fallback.

# Algolia DocSearch (existing) — used by the search UI
PUBLIC_ALGOLIA_APP_ID=
PUBLIC_ALGOLIA_API_KEY=
PUBLIC_ALGOLIA_INDEX_NAME=
