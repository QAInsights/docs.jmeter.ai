{
  "name": "jmeter-docs",
  "type": "module",
  "version": "1.0.0",
  "description": "Community documentation site for Apache JMeter",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-llms-full.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "convert": "node tools/convert.mjs",
    "generate-sidebar": "node scripts/generate-sidebar.mjs",
    "generate-llms-full": "node scripts/generate-llms-full.mjs",
    "lint": "vitest run src/schema-validation.test.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.41.0",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/lora": "^5.2.8",
    "astro": "^7.0.0",
    "lucode-starlight": "^0.1.6",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "fast-xml-parser": "^5.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
